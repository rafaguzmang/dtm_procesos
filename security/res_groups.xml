<odoo>
    <record id="module_category_dtm_procesos" model="ir.module.category">
        <field name="name">Procesos</field>
        <field name="description">Ayuda para administrar permisos</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_dtm_procesos_admin" model="res.groups">
        <field name="name">Procesos Admin</field>
        <field name="category_id" ref="module_category_dtm_procesos"/>
        <field name="implied_ids"  eval="[(4,ref('base.group_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="group_dtm_procesos_user" model="res.groups">
        <field name="name">Procesos User</field>
        <field name="category_id" ref="module_category_dtm_procesos"/>
        <field name="implied_ids"  eval="[(4,ref('base.group_user'))]"/>
    </record>
</odoo>
